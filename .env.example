# ──────────────────────────────────────────────────────────────
# Banco de dados — Neon (PostgreSQL)
# ──────────────────────────────────────────────────────────────
# Crie um projeto em https://neon.tech e copie as connection strings.
#
# DATABASE_URL → string COM pooling (host contém "-pooler"). Usada pela app.
# DIRECT_URL   → string SEM pooling. Usada pelas migrations do Prisma.

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/strikebeer?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/strikebeer?sslmode=require"

# ──────────────────────────────────────────────────────────────
# Admin seed — usuário criado por `pnpm db:seed`
# ──────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@strikebeer.com"
ADMIN_PASSWORD="strikebeer123"

# ──────────────────────────────────────────────────────────────
# UploadThing — imagens dos produtos
# ──────────────────────────────────────────────────────────────
# Crie uma app em https://uploadthing.com e copie o token.
UPLOADTHING_TOKEN="sk_live_xxx"
